# ─────────────────────────────────────────────────────────────
# CSF Auto-Group — config. Copy to  config.env  next to the script.
# Every value is optional; the script uses sane defaults if absent.
# ─────────────────────────────────────────────────────────────

# Message / email language:  en | tr
MSG_LANG=en

# Where alert emails go.
ALERT_MAIL=root@localhost

# ── Thresholds ──────────────────────────────────────────────
# How many banned single IPs in a /24 trigger a permanent block:
THRESHOLD_24=3
# ...and at how many it also gets "do not delete":
THRESHOLD_24_PERMANENT=5
# /16 warn-only threshold (IPs across >=2 distinct /24s):
THRESHOLD_16=5
# Temp /24 grouping threshold:
THRESHOLD_TEMP_24=3
# Temp /16 warn-only threshold:
THRESHOLD_TEMP_16=5

# ── Paths (defaults are standard CSF locations) ─────────────
# DENY_FILE=/etc/csf/csf.deny
# CSF_CONF=/etc/csf/csf.conf
# LOG_FILE=/var/log/csf_autogroup.log
# SAYAC_FILE=/var/lib/csf_autogroup/counter

# Housekeeping
LOG_MAX_LINES=5000
SAYAC_RETENTION_DAYS=180
